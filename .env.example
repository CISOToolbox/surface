# ───────────────────────────────────────────────────────────────
# Surface (standalone) — environment configuration
# Copy to `.env` and edit the values.
# ───────────────────────────────────────────────────────────────

# PostgreSQL credentials (internal, used by the docker-compose DB)
DB_PASSWORD=change-me

# JWT signing secret — use a long random string (e.g. `openssl rand -hex 32`)
JWT_SECRET=change-me-to-a-long-random-string

# Public URL the app is reachable at. Must match the host your users type
# in their browser. Used to build OAuth/OIDC redirect URIs (e.g.
# ${APP_URL}/auth/callback/entra) and to set the `Secure` flag on the
# session cookie when the URL starts with https://.
APP_URL=http://localhost:8087

# ── Authentication providers (optional — configure any combination) ──
# At least one provider must be configured, otherwise the app boots
# unauthenticated only if you explicitly set SURFACE_ALLOW_NO_AUTH=1.

# Token login (legacy): share a pre-shared secret with the operator.
# The first user that logs in becomes admin; subsequent users are plain
# users that an admin must promote.
# AUTH_TOKEN=change-me-to-a-long-random-token

# Microsoft Entra ID / M365
# Register an app at https://entra.microsoft.com → App registrations
# and add ${APP_URL}/auth/callback/entra as a redirect URI.
# ENTRA_CLIENT_ID=
# ENTRA_CLIENT_SECRET=
# ENTRA_TENANT_ID=common        # or your tenant GUID

# Google OAuth 2.0
# Create credentials at https://console.cloud.google.com/apis/credentials
# and add ${APP_URL}/auth/callback/google as an authorized redirect URI.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Generic OIDC provider (Keycloak, Authentik, Authelia, Zitadel, …)
# The issuer must expose /.well-known/openid-configuration. Register the
# callback URI ${APP_URL}/auth/callback/oidc in the provider.
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_ISSUER=https://sso.example.com/realms/main
# OIDC_LABEL=SSO                 # display name of the button on the login page

# Dev-only escape hatch — disable auth entirely. DO NOT set in production.
# SURFACE_ALLOW_NO_AUTH=1
